# Ignore Python cache and compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Ignore C extensions build artifacts
build/
dist/
*.egg-info/
*.egg

# Ignore cpython build directories and files
cpython/
cpython-*/
*/cpython-*/

# Ignore virtual environments
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# Ignore Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Ignore VS Code settings
.vscode/
